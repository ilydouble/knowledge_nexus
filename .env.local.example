# Host development mode.
# Use this when running uvicorn/npm directly on macOS while reusing the existing
# kg-* Docker services through published localhost ports.

NEXUS_STORAGE_BACKEND=memory
VECTOR_BACKEND=milvus

CLOUDREVE_BASE_URL=http://localhost:5212

DATABASE_URL=postgresql://admin:admin123@localhost:5433/smart_building
REDIS_URL=redis://localhost:6380/0

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=admin123

MILVUS_HOST=localhost
MILVUS_PORT=19530

MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

OPENAI_API_KEY=

