#!/usr/bin/env python3
"""knowledge-os CLI — thin HTTP client for the Knowledge OS REST API.

Drives the extract → review → commit → query workflow against a running
Knowledge OS backend (started via ./start.sh). Stdlib only: needs just
python3 and the API listening on http://localhost:8000.

Override the base URL with the KN_API_URL environment variable.
"""
from __future__ import annotations

import argparse
import json
import os
import sys
import urllib.error
import urllib.parse
import urllib.request

BASE = os.environ.get("KN_API_URL", "http://localhost:8000").rstrip("/")


def _req(method: str, path: str, body=None, query=None):
    url = BASE + path
    if query:
        q = {k: v for k, v in query.items() if v not in (None, "")}
        if q:
            url += "?" + urllib.parse.urlencode(q)
    data = json.dumps(body).encode() if body is not None else None
    req = urllib.request.Request(url, data=data, method=method)
    if data is not None:
        req.add_header("Content-Type", "application/json")
    try:
        with urllib.request.urlopen(req, timeout=300) as resp:
            return json.loads(resp.read().decode() or "{}")
    except urllib.error.HTTPError as exc:
        sys.exit(f"HTTP {exc.code}: {exc.read().decode()}")
    except urllib.error.URLError as exc:
        sys.exit(f"Cannot reach {BASE} — is the backend running? ({exc.reason})")


def _out(obj) -> None:
    print(json.dumps(obj, ensure_ascii=False, indent=2))


def _enc(uri: str) -> str:
    return urllib.parse.quote(uri, safe="")


def cmd_dashboard(a):
    _out(_req("GET", "/api/admin/dashboard"))


def cmd_batches(a):
    _out(_req("GET", "/api/admin/candidates",
              query={"status": a.status, "source_uri": a.source_uri, "limit": a.limit}))


def cmd_batch(a):
    _out(_req("GET", f"/api/admin/candidates/{a.batch_id}"))


def cmd_extract(a):
    body = {"uri": a.uri, "requested_by": a.requested_by}
    if a.instructions:
        body["instructions"] = a.instructions
    if a.template:
        body["template_ids"] = a.template
    _out(_req("POST", "/api/admin/candidates/extract", body=body))


def cmd_accept_all(a):
    _out(_req("POST", f"/api/admin/candidates/{a.batch_id}/accept-all"))


def cmd_reject_all(a):
    _out(_req("POST", f"/api/admin/candidates/{a.batch_id}/reject-all"))


def cmd_review(a):
    edits = [{"item_id": i, "status": "accepted"} for i in (a.accept or [])]
    edits += [{"item_id": i, "status": "rejected"} for i in (a.reject or [])]
    if not edits:
        sys.exit("Provide at least one --accept or --reject item id")
    _out(_req("PATCH", f"/api/admin/candidates/{a.batch_id}", body={"edits": edits}))


def cmd_preview(a):
    _out(_req("POST", f"/api/admin/candidates/{a.batch_id}/preview"))


def cmd_commit(a):
    _out(_req("POST", f"/api/admin/candidates/{a.batch_id}/commit"))


def cmd_ask(a):
    _out(_req("POST", "/api/graph/ask",
              body={"question": a.question, "requested_by": a.requested_by}))


def cmd_graph(a):
    _out(_req("GET", "/api/graph", query={"uri": a.uri}))


def cmd_evidence(a):
    _out(_req("GET", "/api/admin/graph/evidence",
              query={"graph_item_id": a.item, "source_uri": a.source}))


def cmd_stale(a):
    _out(_req("GET", "/api/admin/graph/stale"))


def cmd_mark_deleted(a):
    _out(_req("POST", f"/api/admin/documents/{_enc(a.uri)}/mark-source-deleted"))


def cmd_purge(a):
    _out(_req("POST", f"/api/admin/documents/{_enc(a.uri)}/purge", body={"mode": a.mode}))


def cmd_delete_graph(a):
    _out(_req("DELETE", f"/api/admin/documents/{_enc(a.uri)}/graph"))


def cmd_scan(a):
    _out(_req("POST", "/api/cloudreve/scan"))


def cmd_scan_status(a):
    _out(_req("GET", "/api/cloudreve/scan/status"))


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="kn", description="Knowledge OS workflow CLI")
    sub = p.add_subparsers(dest="cmd", required=True)

    sub.add_parser("dashboard", help="health + counts overview").set_defaults(fn=cmd_dashboard)

    b = sub.add_parser("batches", help="list candidate batches")
    b.add_argument("--status"); b.add_argument("--source-uri", dest="source_uri")
    b.add_argument("--limit", type=int, default=50); b.set_defaults(fn=cmd_batches)

    g = sub.add_parser("batch", help="show one batch"); g.add_argument("batch_id")
    g.set_defaults(fn=cmd_batch)

    e = sub.add_parser("extract", help="auto-extract candidates from a cloudreve:// uri")
    e.add_argument("uri"); e.add_argument("--instructions")
    e.add_argument("--requested-by", dest="requested_by", default="pi-agent")
    e.add_argument("--template", action="append"); e.set_defaults(fn=cmd_extract)

    for name, fn in (("accept-all", cmd_accept_all), ("reject-all", cmd_reject_all),
                     ("preview", cmd_preview), ("commit", cmd_commit)):
        sp = sub.add_parser(name); sp.add_argument("batch_id"); sp.set_defaults(fn=fn)

    r = sub.add_parser("review", help="accept/reject specific item ids")
    r.add_argument("batch_id"); r.add_argument("--accept", action="append")
    r.add_argument("--reject", action="append"); r.set_defaults(fn=cmd_review)

    q = sub.add_parser("ask", help="natural-language graph Q&A"); q.add_argument("question")
    q.add_argument("--requested-by", dest="requested_by", default="pi-agent")
    q.set_defaults(fn=cmd_ask)

    gr = sub.add_parser("graph", help="dump full graph or 1-hop neighborhood")
    gr.add_argument("--uri"); gr.set_defaults(fn=cmd_graph)

    ev = sub.add_parser("evidence", help="evidence by item id or source uri")
    ev.add_argument("--item"); ev.add_argument("--source"); ev.set_defaults(fn=cmd_evidence)

    sub.add_parser("stale", help="stale/purged evidence report").set_defaults(fn=cmd_stale)

    md = sub.add_parser("mark-deleted", help="soft-delete a source uri"); md.add_argument("uri")
    md.set_defaults(fn=cmd_mark_deleted)

    pu = sub.add_parser("purge", help="purge knowledge for a source uri"); pu.add_argument("uri")
    pu.add_argument("--mode", default="knowledge"); pu.set_defaults(fn=cmd_purge)

    dg = sub.add_parser("delete-graph", help="HARD-delete Neo4j nodes/edges for a source uri")
    dg.add_argument("uri"); dg.set_defaults(fn=cmd_delete_graph)

    sub.add_parser("scan", help="trigger a Cloudreve scan").set_defaults(fn=cmd_scan)
    sub.add_parser("scan-status", help="last scan result").set_defaults(fn=cmd_scan_status)
    return p


def main() -> None:
    args = build_parser().parse_args()
    args.fn(args)


if __name__ == "__main__":
    main()
