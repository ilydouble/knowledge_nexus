# Knowledge Nexus environment templates
#
# For host development, copy:
#   cp .env.local.example .env
#
# For Docker sidecar mode on the existing kg-network, copy:
#   cp .env.docker.example .env
#
# The checked-in examples use local-development credentials from the existing
# kg-* Docker stack only. Do not reuse them in production.

NEXUS_STORAGE_BACKEND=memory
VECTOR_BACKEND=milvus
CLOUDREVE_BASE_URL=http://localhost:5212
OPENAI_API_KEY=
