# Docker sidecar mode.
# Use this when running Nexus containers attached to the existing kg-network.

NEXUS_STORAGE_BACKEND=memory
VECTOR_BACKEND=milvus

CLOUDREVE_BASE_URL=http://host.docker.internal:5212

DATABASE_URL=postgresql://admin:admin123@kg-postgres:5432/smart_building
REDIS_URL=redis://kg-redis:6379/0

NEO4J_URI=bolt://kg-neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=admin123

MILVUS_HOST=kg-milvus
MILVUS_PORT=19530

MINIO_ENDPOINT=http://kg-minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

OPENAI_API_KEY=
